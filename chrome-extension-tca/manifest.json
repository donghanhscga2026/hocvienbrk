{
  "manifest_version": 3,
  "name": "TCA to BRK Sync",
  "version": "7.6.1",
  "description": "Sync TCA to BRK v7.6.1 - Hiển thị điểm mới, màu đỏ nếu khác DB, xanh nếu trùng",
  "permissions": [
    "activeTab",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "*://portal.tca.com.vn/*",
    "*://giautoandien.io.vn/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "action": {
    "default_title": "TCA Sync"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://portal.tca.com.vn/*"],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected-script.js"],
      "matches": ["*://portal.tca.com.vn/*"]
    }
  ]
}
