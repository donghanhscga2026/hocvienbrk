generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                           Int                   @id @default(autoincrement())
  name                         String?
  email                        String                @unique
  emailVerified                DateTime?
  image                        String?
  password                     String?
  phone                        String?               @unique
  role                         Role                  @default(STUDENT)
  referrerId                   Int?
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  passwordChanged              Boolean               @default(false)
  affiliateCode                String?               @unique
  accounts                     Account[]
  commissions                  AffiliateCommission[]
  affiliateLinks               AffiliateLink[]
  affiliatePayouts             AffiliatePayout[]
  affiliateRefs                AffiliateRef[]
  wallet                       AffiliateWallet?
  courses                      Course[]
  emailCampaigns               EmailCampaign[]       @relation("UserToEmailCampaign")
  enrollments                  Enrollment[]       @relation("StudentEnrollment")
  enrollmentReferrals          Enrollment[]       @relation("EnrollmentReferrer")
  lessonComments               LessonComment[]       @relation("UserToLessonComment")
  posts                        Post[]                @relation("UserToPost")
  postComments                 PostComment[]         @relation("UserToPostComment")
  registrationPointsAsReferee  RegistrationPoint[]   @relation("RefereeRegistration")
  registrationPointsAsReferrer RegistrationPoint[]   @relation("ReferrerRegistration")
  sessions                     Session[]
  emailLogs                    EmailLog[]
  siteProfile                  SiteProfile?
  referrer                     User?                 @relation("ReferrerToReferee", fields: [referrerId], references: [id])
  referrals                    User[]                @relation("ReferrerToReferee")
  roadmap                      UserRoadmap?
  systems                      System[]
  tcaMembers                   TCAMember[]
  closureAsAncestor            UserClosure[]         @relation("ClosureAncestor")
  closureAsDescendant          UserClosure[]         @relation("ClosureDescendant")
  profileMemberships           SiteProfileMember[]
  brkWallet                    BrkWallet?
  brkSystemsCreated            SystemTree[]
  bankAccounts                 UserBankAccount[]

  @@index([email])
  @@index([phone])
  @@index([referrerId])
  @@index([affiliateCode])
}

model UserClosure {
  ancestorId   Int  @map("ancestor_id")
  descendantId Int  @map("descendant_id")
  depth        Int  @default(0)
  ancestor     User @relation("ClosureAncestor", fields: [ancestorId], references: [id])
  descendant   User @relation("ClosureDescendant", fields: [descendantId], references: [id])

  @@id([ancestorId, descendantId])
  @@index([ancestorId])
  @@index([descendantId])
  @@index([depth])
  @@map("user_closure")
}

model EmailSender {
  id               Int                   @id @default(autoincrement())
  label            String
  email            String
  isMain           Boolean               @default(false)
  provider         String                @default("gmail")
  clientId         String?
  clientSecret     String?
  refreshToken     String?
  apiKeyEncrypted  String?
  apiKeyEnvVar     String?
  senderName       String?
  dailyLimit       Int                   @default(480)
  sentToday        Int                   @default(0)
  lastResetAt      DateTime              @default(now())
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  cooldownUntil    DateTime?
  lastUsedAt       DateTime?
  maxPerBatch      Int                   @default(20)
  pauseDurationMax Int                   @default(30)
  pauseDurationMin Int                   @default(10)
  staggerDelayMax  Int                   @default(15)
  staggerDelayMin  Int                   @default(5)
  warmupPhase      Int                   @default(0)
  campaigns        EmailCampaignSender[]
  senderLogs       EmailSenderLog[]
}

model EmailCampaign {
  id               Int                   @id @default(autoincrement())
  title            String
  status           CampaignStatus        @default(DRAFT)
  notificationType String
  linkedEntityId   String?
  recipientSource  String
  recipientFilter  Json?
  recipientCsvData String?
  subject          String
  htmlContent      String
  totalRecipients  Int                   @default(0)
  sentCount        Int                   @default(0)
  failedCount      Int                   @default(0)
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  createdBy        Int
  creator          User                  @relation("UserToEmailCampaign", fields: [createdBy], references: [id])
  logs             EmailCampaignLog[]
  senders          EmailCampaignSender[]
}

model EmailCampaignSender {
  id            Int           @id @default(autoincrement())
  campaignId    Int
  senderId      Int
  assignedCount Int           @default(0)
  sentCount     Int           @default(0)
  campaign      EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sender        EmailSender   @relation(fields: [senderId], references: [id])
}

model EmailCampaignLog {
  id         Int           @id @default(autoincrement())
  campaignId Int
  senderId   Int?
  toEmail    String
  status     String
  errorCode  String?
  errorType  String?
  sentAt     DateTime      @default(now())
  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model EmailLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  email      String
  type       String
  provider   String
  status     String
  messageId  String?
  error      String?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id])
}

model EmailSenderLog {
  id              Int           @id @default(autoincrement())
  senderId        Int
  sender          EmailSender   @relation(fields: [senderId], references: [id])
  date            DateTime      @default(now())
  sentCount       Int      @default(0)
  failedCount     Int      @default(0)
  bounceCount     Int      @default(0)
  cooldownCount   Int      @default(0)
  cooldownMinutes Int      @default(0)

  @@unique([senderId, date])
}

model EmailBlacklist {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  reason     String
  campaignId Int?
  createdAt  DateTime @default(now())
}

model UserRoadmap {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  targetPointId Int      @default(1)
  customPath    Json?
  goal          Json?
  surveyResults Json?
  updatedAt     DateTime @updatedAt
  history       Json?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RoadmapPoint {
  id        Int      @id @default(autoincrement())
  pointId   Int      @unique
  name      String
  courseIds String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id         String        @id @default(cuid())
  title      String
  content    String
  image      String?
  published  Boolean       @default(true)
  pin        Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  authorId   Int
  categoryId Int?
  author     User          @relation("UserToPost", fields: [authorId], references: [id], onDelete: Cascade)
  category   PostCategory? @relation(fields: [categoryId], references: [id])
  comments   PostComment[]

  @@index([authorId])
  @@index([categoryId])
}

model PostComment {
  id        Int      @id @default(autoincrement())
  postId    String
  userId    Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation("UserToPostComment", fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model PostCategory {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String?  @unique
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  posts       Post[]

  @@index([order])
}

model Account {
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model SystemConfig {
  key   String @id
  value Json
}

model Survey {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  flow        Json
  isActive    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  profileId   Int?
  profile     SiteProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model ReservedId {
  id        Int      @id
  note      String?
  createdAt DateTime @default(now())
}

model CourseCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  order     Int      @default(0)
  color     String   @default("#6366f1")
  icon      String?
  createdAt DateTime @default(now())
  courses   Course[]
}

model Course {
  id            Int                 @id @default(autoincrement())
  id_khoa       String              @unique
  name_lop      String
  name_khoa     String?
  date_join     String?
  status        Boolean             @default(true)
  mo_ta_ngan    String?
  mo_ta_dai     String?
  link_anh_bia  String?             @map("link_anh_bia_khoa")
  link_zalo     String?
  phi_coc       Int                 @default(0)
  vipExempt     Boolean             @default(false)
  noidung_stk   String?
  file_email    String?
  noidung_email String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  type          CourseType          @default(NORMAL)
  pin           Int                 @default(0)
  category      String              @default("Khác")
  categoryId    Int?
  courseCategory CourseCategory?    @relation(fields: [categoryId], references: [id])
  teacherId     Int?
  teacher       User?               @relation(fields: [teacherId], references: [id])
  teacherBankAccountId Int?
  teacherBankAccount   UserBankAccount? @relation("CourseTeacherBank", fields: [teacherBankAccountId], references: [id])
  libAccesses   CourseLibAccess[]
  testimonials  CourseTestimonial[]
  enrollments   Enrollment[]
  landingPages  LandingPage[]
  lessons       Lesson[]
  systemTree    SystemTree?
  autoVerifyConfig AutoVerifyConfig?

  @@index([teacherId])
}

model AutoVerifyConfig {
  id         Int      @id @default(autoincrement())
  courseId   Int      @unique
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  emailFrom  String   // địa chỉ gửi email TBGD, VD: info@sacombank.com.vn
  bankName   String   // tên ngân hàng, VD: Sacombank
  emailQuery String   // câu query Gmail, VD: "sacombank thong bao giao dich"
  onSystem   Int?     // BRK system ID để auto-activate (null = không kích hoạt BRK)
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([enabled])
  @@map("auto_verify_config")
}

model Lesson {
  id               String           @id @default(cuid())
  courseId         Int
  title            String
  videoUrl         String?
  content          String?
  order            Int
  isDailyChallenge Boolean          @default(false)
  type             LessonType       @default(VIDEO)
  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  comments         LessonComment[]
  progress         LessonProgress[]

  @@unique([courseId, order])
}

model Enrollment {
  id               Int              @id @default(autoincrement())
  userId           Int
  courseId         Int
  status           EnrollmentStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  link_anh_coc     String?
  phi_coc          Int              @default(0)
  startedAt        DateTime?
  challengeDays    Int?
  resetAt          DateTime?
  lastLessonId     String?
  referrerId       Int?
  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user             User             @relation("StudentEnrollment", fields: [userId], references: [id], onDelete: Cascade)
  referrer         User?            @relation("EnrollmentReferrer", fields: [referrerId], references: [id])
  lessonProgress   LessonProgress[]
  payment          Payment?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([referrerId])
}

model LessonProgress {
  id           Int        @id @default(autoincrement())
  enrollmentId Int
  lessonId     String
  scores       Json?
  totalScore   Int        @default(0)
  assignment   Json?
  status       String     @default("IN_PROGRESS")
  maxTime      Float      @default(0)
  submittedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  duration     Float      @default(0)
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@index([lessonId])
  @@index([status])
}

model LessonComment {
  id        Int      @id @default(autoincrement())
  lessonId  String
  userId    Int
  content   String
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user      User     @relation("UserToLessonComment", fields: [userId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([userId])
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  detail    String
  imageUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model BulkImportLog {
  id          String   @id @default(uuid())
  courseId    Int
  userId      Int
  summary     Json
  createdAt   DateTime @default(now())
  revertedAt  DateTime?

  @@index([courseId])
  @@index([createdAt])
}

model CourseLibAccess {
  id        Int      @id @default(autoincrement())
  courseId  Int
  email     String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, email])
  @@index([courseId])
  @@index([email])
}

model Payment {
  id              Int           @id @default(autoincrement())
  enrollmentId    Int           @unique
  amount          Int
  bankName        String?
  accountNumber   String?
  transferTime    DateTime?
  content         String?
  phone           String?
  courseCode      String?
  proofImage      String?
  status          PaymentStatus @default(PENDING)
  verifiedAt      DateTime?
  verifyMethod    String?
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  qrCodeUrl       String?
  transferContent String?
  enrollment      Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

model YouTubeToken {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  channelId    String?
  channelTitle String?
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SystemTree {
  id         Int      @id @default(autoincrement())
  onSystem   Int      @unique
  createdAt  DateTime @default(now())
  nameSystem String   @map("name_system")
  courseId   Int?     @unique
  course     Course?  @relation(fields: [courseId], references: [id])
  creatorId  Int?
  creator    User?    @relation(fields: [creatorId], references: [id])
  fee        Decimal  @default(1) @db.Decimal(12, 2)
  durationDays    Int  @default(30)
  graceDays       Int  @default(3)
  returnPct       Decimal @default(21.0) @db.Decimal(5, 2)
  revenueSharePct Decimal @default(2.0) @db.Decimal(5, 2)
  revenueShareIntervalDays Int @default(3)
  pointsPerDollar Decimal @default(17) @db.Decimal(10, 2)
  brkLevelConfigs BrkLevelConfig[]
  brkRevenuePools BrkRevenuePool[]
  systems         System[]

  @@index([courseId])
  @@index([creatorId])
  @@map("system_tree")
}

model System {
  autoId               Int             @id @default(autoincrement())
  userId               Int
  onSystem             Int
  refSysId             Int             @default(0)
  createdAt            DateTime        @default(now())
  status               BrkMemberStatus @default(PENDING)
  activatedAt          DateTime?
  expiresAt            DateTime?
  gracePeriodEnd       DateTime?
  level                Int             @default(1)
  totalPoints          Decimal         @default(0) @db.Decimal(14, 2)
  giftClaimed          Boolean         @default(false)
  user                 User            @relation(fields: [userId], references: [id])
  systemTree           SystemTree      @relation(fields: [onSystem], references: [onSystem])
  closuresAsAncestor   SystemClosure[] @relation("SystemClosureAncestor")
  closuresAsDescendant SystemClosure[] @relation("SystemClosureDescendant")
  brkLevelUpRecords    BrkLevelUpRecord[]
  brkReferralBonuses   BrkReferralBonus[]

  @@unique([userId, onSystem])
  @@index([userId])
  @@index([onSystem])
  @@index([refSysId])
  @@map("system")
}

model SystemClosure {
  ancestorId   Int
  descendantId Int
  depth        Int    @default(0)
  systemId     Int
  ancestor     System @relation("SystemClosureAncestor", fields: [ancestorId], references: [autoId])
  descendant   System @relation("SystemClosureDescendant", fields: [descendantId], references: [autoId])

  @@id([ancestorId, descendantId, systemId])
  @@index([ancestorId])
  @@index([descendantId])
  @@index([systemId])
  @@index([depth])
  @@map("system_closure")
}

model BrkLevelConfig {
  id              Int       @id @default(autoincrement())
  systemId        Int
  level           Int
  pointsRequired  Decimal   @db.Decimal(14, 2)
  personalFeePct  Decimal   @db.Decimal(5, 2)
  giftValue       Int       @default(0)
  timeLimitDays   Int?
  systemTree      SystemTree @relation(fields: [systemId], references: [onSystem])
  branchReqs      BrkLevelBranchReq[]

  @@unique([systemId, level])
  @@index([systemId])
  @@map("brk_level_config")
}

model BrkLevelBranchReq {
  id          Int            @id @default(autoincrement())
  configId    Int
  branchLevel Int
  count       Int
  config      BrkLevelConfig @relation(fields: [configId], references: [id])

  @@index([configId])
  @@map("brk_level_branch_req")
}

model BrkWallet {
  id             Int               @id @default(autoincrement())
  userId         Int               @unique
  balance        Decimal           @default(0) @db.Decimal(14, 2)
  brkd           Decimal           @default(0) @db.Decimal(14, 2)
  voucherBalance Decimal           @default(0) @db.Decimal(14, 2)
  totalEarned    Decimal           @default(0) @db.Decimal(14, 2)
  totalWithdrawn Decimal           @default(0) @db.Decimal(14, 2)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id])
  transactions   BrkTransaction[]

  @@index([userId])
  @@map("brk_wallet")
}

model BrkTransaction {
  id            Int               @id @default(autoincrement())
  walletId      Int
  amount        Decimal           @db.Decimal(14, 2)
  type          BrkTransactionType
  description   String
  refId         String?
  balanceType   BalanceType       @default(CASH)
  balanceBefore Decimal           @db.Decimal(14, 2)
  balanceAfter  Decimal           @db.Decimal(14, 2)
  createdAt     DateTime          @default(now())
  wallet        BrkWallet         @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@index([type])
  @@map("brk_transaction")
}

model BrkRevenuePool {
  id             Int                  @id @default(autoincrement())
  systemId       Int
  roundNumber    Int
  periodStart    DateTime
  periodEnd      DateTime
  totalRevenue   Decimal              @db.Decimal(14, 2)
  poolAmount     Decimal              @db.Decimal(14, 2)
  qualifiedCount Int                  @default(0)
  status         BrkRevenuePoolStatus @default(PENDING)
  distributedAt  DateTime?
  createdAt      DateTime             @default(now())
  systemTree     SystemTree           @relation(fields: [systemId], references: [onSystem])
  awards         BrkRevenueAward[]

  @@unique([systemId, roundNumber])
  @@index([systemId])
  @@map("brk_revenue_pool")
}

model BrkRevenueAward {
  id     Int            @id @default(autoincrement())
  poolId Int
  userId Int
  amount Decimal        @db.Decimal(14, 2)
  paid   Boolean        @default(false)
  pool   BrkRevenuePool @relation(fields: [poolId], references: [id])

  @@index([poolId])
  @@index([userId])
  @@map("brk_revenue_award")
}

model BrkLevelUpRecord {
  id           Int      @id @default(autoincrement())
  userId       Int
  onSystem     Int
  fromLevel    Int
  toLevel      Int
  promotedAt   DateTime @default(now())
  giftClaimed  Boolean  @default(false)
  giftClaimedAt DateTime?
  system       System   @relation(fields: [userId, onSystem], references: [userId, onSystem])

  @@index([userId, onSystem])
  @@map("brk_level_up_record")
}

model BrkReferralBonus {
  id        Int      @id @default(autoincrement())
  userId    Int
  onSystem  Int
  f1Count   Int      @default(2)
  courseId  Int?
  claimed   Boolean  @default(false)
  claimedAt DateTime?
  system    System   @relation(fields: [userId, onSystem], references: [userId, onSystem])

  @@index([userId, onSystem])
  @@map("brk_referral_bonus")
}

model TCAMember {
  id            Int       @id @default(autoincrement())
  tcaId         Int       @unique
  userId        Int
  type          String
  groupName     String?
  name          String
  personalScore Decimal?  @db.Decimal(10, 3)
  totalScore    Decimal?  @db.Decimal(10, 3)
  level         Int?
  location      String?
  personalRate  String?
  teamRate      String?
  hasBH         Boolean   @default(false)
  hasTD         Boolean   @default(false)
  phone         String?
  email         String?
  address       String?
  joinDate      DateTime?
  contractDate  DateTime?
  promotionDate DateTime?
  parentTcaId   Int?
  parentName    String?
  teamSize      Int       @default(0)
  lastSyncedAt  DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  chuc_danh     String?
  user          User      @relation(fields: [userId], references: [id])

  @@index([tcaId])
  @@index([userId])
  @@index([parentTcaId])
  @@map("tca_member")
}

model TCASyncHistory {
  id           Int      @id @default(autoincrement())
  syncId       String
  action       String
  tableName    String
  recordId     Int?
  beforeData   Json?
  afterData    Json?
  tcaId        Int?
  totalRecords Int
  status       String   @default("PENDING")
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([syncId])
  @@index([tcaId])
  @@index([tableName])
  @@index([createdAt])
  @@map("tca_sync_history")
}

model UserTest {
  id                  Int               @id @default(autoincrement())
  name                String?
  email               String            @unique
  emailVerified       DateTime?
  image               String?
  password            String?
  passwordChanged     Boolean           @default(false)
  phone               String?           @unique
  role                Role              @default(STUDENT)
  referrerId          Int?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  closureAsAncestor   UserClosureTest[] @relation("TestClosureAncestor")
  closureAsDescendant UserClosureTest[] @relation("TestClosureDescendant")

  @@index([email])
  @@index([phone])
  @@index([referrerId])
  @@map("user_test")
}

model UserClosureTest {
  ancestorId   Int      @map("ancestor_id")
  descendantId Int      @map("descendant_id")
  depth        Int      @default(0)
  ancestor     UserTest @relation("TestClosureAncestor", fields: [ancestorId], references: [id])
  descendant   UserTest @relation("TestClosureDescendant", fields: [descendantId], references: [id])

  @@id([ancestorId, descendantId])
  @@index([ancestorId])
  @@index([descendantId])
  @@index([depth])
  @@map("user_closure_test")
}

model SystemTest {
  autoId    Int      @id @default(autoincrement())
  userId    Int
  onSystem  Int
  refSysId  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, onSystem])
  @@index([userId])
  @@index([onSystem])
  @@index([refSysId])
  @@map("system_test")
}

model SystemClosureTest {
  ancestorId   Int
  descendantId Int
  depth        Int @default(0)
  systemId     Int

  @@id([ancestorId, descendantId, systemId])
  @@index([ancestorId])
  @@index([descendantId])
  @@index([systemId])
  @@index([depth])
  @@map("system_closure_test")
}

model TCAMemberTest {
  id            Int       @id @default(autoincrement())
  tcaId         Int       @unique
  userId        Int
  type          String    @default("item")
  groupName     String?
  name          String
  personalScore Decimal?  @db.Decimal(10, 3)
  totalScore    Decimal?  @db.Decimal(10, 3)
  level         Int?
  location      String?
  personalRate  String?
  teamRate      String?
  hasBH         Boolean   @default(false)
  hasTD         Boolean   @default(false)
  phone         String?
  email         String?
  address       String?
  joinDate      DateTime?
  contractDate  DateTime?
  promotionDate DateTime?
  parentTcaId   Int?
  parentName    String?
  teamSize      Int       @default(0)
  lastSyncedAt  DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tcaId])
  @@index([userId])
  @@index([parentTcaId])
  @@map("tca_member_test")
}

model Theme {
  id           String        @id
  name         String
  description  String?
  colors       Json
  typography   Json
  layout       Json
  animations   Json?
  effects      Json?
  isLocked     Boolean       @default(false)
  isActive     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  siteProfiles SiteProfile[]
  siteSettings SiteSettings?

  @@index([id])
}

model LandingPage {
  id               Int                   @id @default(autoincrement())
  slug             String                @unique
  title            String
  subtitle         String?
  description      String?
  heroImage        String?
  ctaText          String                @default("Đăng ký ngay")
  ctaLink          String?
  template         String                @default("hero-cta")
  config           Json?
  customCommission Json?
  courseId         Int?
  viewCount        Int                   @default(0)
  clickCount       Int                   @default(0)
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  profileId        Int?
  clicks           AffiliateClick[]
  conversions      AffiliateConversion[]
  course           Course?               @relation(fields: [courseId], references: [id])
  profile          SiteProfile?          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  registrations    RegistrationPoint[]

  @@index([slug])
  @@index([isActive])
  @@index([courseId])
}

model AffiliateCampaign {
  id                    Int                   @id @default(autoincrement())
  name                  String
  slug                  String                @unique
  description           String?
  isActive              Boolean               @default(true)
  maxLevels             Int                   @default(3)
  pendingDays           Int                   @default(30)
  minPayout             Float                 @default(200000)
  taxRate               Float                 @default(0)
  feeAmount             Float                 @default(3300)
  pointsPerRegistration Float                 @default(1.0)
  pointsRequired        Float                 @default(10.0)
  pointRedemptionValue  Float                 @default(386868)
  autoRedeem            Boolean               @default(false)
  redemptionCourseId    Int?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  isDefault             Boolean               @default(false)
  landingOverrides      Json?
  profileId             Int?                  @unique
  profile               SiteProfile?          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  conversions           AffiliateConversion[]
  levels                AffiliateLevel[]
  links                 AffiliateLink[]
  registrations         RegistrationPoint[]

  @@index([isActive])
}

model AffiliateLevel {
  id         Int               @id @default(autoincrement())
  campaignId Int
  level      Int
  percentage Float
  minOrder   Float?
  campaign   AffiliateCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, level])
  @@index([campaignId])
}

model AffiliateLink {
  id          Int                   @id @default(autoincrement())
  userId      Int
  campaignId  Int
  code        String                @unique
  name        String?
  source      String?
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  clicks      AffiliateClick[]
  conversions AffiliateConversion[]
  campaign    AffiliateCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user        User                  @relation(fields: [userId], references: [id])

  @@unique([userId, campaignId, name])
  @@index([userId])
  @@index([campaignId])
}

model AffiliateClick {
  id          Int           @id @default(autoincrement())
  linkId      Int
  ipAddress   String?
  userAgent   String?
  referer     String?
  url         String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  deviceType  String?
  country     String?
  city        String?
  createdAt   DateTime      @default(now())
  landingId   Int?
  landingSlug String?
  landing     LandingPage?  @relation(fields: [landingId], references: [id])
  link        AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, createdAt])
  @@index([ipAddress, createdAt])
  @@index([landingSlug])
  @@index([landingId])
}

model AffiliateRef {
  id          Int      @id @default(autoincrement())
  refKey      String   @unique
  userId      Int
  type        RefType  @default(USER_ID)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AffiliateConversion {
  id           Int                   @id @default(autoincrement())
  linkId       Int
  campaignId   Int
  customerId   Int
  enrollmentId Int?
  orderId      String?
  orderAmount  Float
  productType  ProductType           @default(COURSE)
  status       ConversionStatus      @default(PENDING)
  fraudFlags   String[]
  pendingUntil DateTime
  approvedAt   DateTime?
  createdAt    DateTime              @default(now())
  landingId    Int?
  landingSlug  String?
  commissions  AffiliateCommission[]
  campaign     AffiliateCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  landing      LandingPage?          @relation(fields: [landingId], references: [id])
  link         AffiliateLink         @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
  @@index([customerId])
  @@index([pendingUntil])
  @@index([landingSlug])
  @@index([landingId])
}

model RegistrationPoint {
  id          Int               @id @default(autoincrement())
  referrerId  Int
  refereeId   Int
  campaignId  Int
  points      Float             @default(1.0)
  status      PointStatus       @default(PENDING)
  earnedAt    DateTime          @default(now())
  confirmedAt DateTime?
  landingId   Int?
  landingSlug String?
  campaign    AffiliateCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  landing     LandingPage?      @relation(fields: [landingId], references: [id])
  referee     User              @relation("RefereeRegistration", fields: [refereeId], references: [id])
  referrer    User              @relation("ReferrerRegistration", fields: [referrerId], references: [id])

  @@index([referrerId])
  @@index([refereeId])
  @@index([campaignId])
  @@index([status])
  @@index([landingSlug])
}

model AffiliateCommission {
  id           Int                 @id @default(autoincrement())
  conversionId Int
  affiliateId  Int
  level        Int
  percentage   Float
  grossAmount  Float
  taxAmount    Float               @default(0)
  feeAmount    Float               @default(0)
  netAmount    Float
  status       CommissionStatus    @default(PENDING)
  availableAt  DateTime?
  paidAt       DateTime?
  createdAt    DateTime            @default(now())
  affiliate    User                @relation(fields: [affiliateId], references: [id])
  conversion   AffiliateConversion @relation(fields: [conversionId], references: [id], onDelete: Cascade)

  @@index([affiliateId, status])
  @@index([availableAt])
}

model AffiliateWallet {
  id             Int                    @id @default(autoincrement())
  userId         Int                    @unique
  points         Float                  @default(0)
  balance        Float                  @default(0)
  pendingBalance Float                  @default(0)
  totalEarned    Float                  @default(0)
  totalPaid      Float                  @default(0)
  updatedAt      DateTime               @updatedAt
  transactions   AffiliateTransaction[]
  user           User                   @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AffiliateTransaction {
  id            Int               @id @default(autoincrement())
  walletId      Int
  amount        Float
  type          TransactionType
  description   String
  refId         String?
  balanceBefore Float
  balanceAfter  Float
  status        TransactionStatus @default(COMPLETED)
  createdAt     DateTime          @default(now())
  wallet        AffiliateWallet   @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@index([type])
}

model AffiliatePayout {
  id            Int          @id @default(autoincrement())
  userId        Int
  amount        Float
  taxAmount     Float        @default(0)
  feeAmount     Float        @default(0)
  netAmount     Float
  bankName      String
  bankAccount   String
  accountHolder String
  qrCodeUrl     String?
  status        PayoutStatus @default(PENDING)
  notes         String?
  processedAt   DateTime?
  createdAt     DateTime     @default(now())
  user          User         @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([userId, status])
}

model SiteSettings {
  id        String   @id @default("global")
  themeId   String   @unique @default("classic")
  language  String   @default("vi")
  updatedAt DateTime @updatedAt
  theme     Theme    @relation(fields: [themeId], references: [id])
}

model CourseTestimonial {
  id         Int      @id @default(autoincrement())
  courseId   Int
  name       String
  role       String?
  avatar     String?
  content    String
  rating     Int      @default(5)
  courseName String?
  isFeatured Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, isActive])
  @@index([isFeatured])
}

model Tool {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  url         String
  roles       Role[]
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([slug])
}

model SiteProfile {
  id                   Int                @id @default(autoincrement())
  userId               Int?               @unique
  slug                 String             @unique
  isActive             Boolean            @default(false)
  isDefault            Boolean            @default(false)
  heroImage            String?
  heroOverlay          Float?             @default(0.3)
  title                String?
  subtitle             String?
  messageContent       String?
  messageDetail        String?
  messageImage         String?
  surveyTitle          String?
  customRoadmap        Json?
  roadmapTitle         String?
  courseIds            Json?
  coursesTitle         String?
  allCoursesTitle      String?
  showAllCourses       Boolean            @default(true)
  showCommunity        Boolean            @default(true)
  communityTitle       String?
  footerText           String?
  footerLinks          Json?
  metaTitle            String?
  metaDescription      String?
  metaImage            String?
  themeId              String?
  accentColor          String?
  backgroundColor      String?
  textColor            String?
  viewCount            Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  selectedSurveyId     Int?
  communityCategoryId  Int?
  communityLimit       Int                @default(10)
  courseCategoryFilter Json?
  greetingMessages     Json?
  affiliateCampaign    AffiliateCampaign?
  landingPages         LandingPage[]
  theme                Theme?             @relation(fields: [themeId], references: [id])
  user                 User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  surveys              Survey[]
  members              SiteProfileMember[]

  @@index([slug])
  @@index([userId])
  @@index([isActive])
}

model SiteProfileMember {
  id        Int               @id @default(autoincrement())
  profileId Int
  userId    Int
  role      String            @default("ASSOCIATE")
  createdAt DateTime          @default(now())
  profile   SiteProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([profileId, userId])
  @@index([profileId])
  @@index([userId])
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  syncId    String
  tableName String   @db.VarChar(50)
  recordId  Int
  action    String   @db.VarChar(20)
  oldData   String?
  newData   String?
  createdAt DateTime @default(now())

  @@unique([syncId, tableName, recordId])
  @@index([syncId])
}

model AccountAssistantStep {
  id             Int      @id @default(autoincrement())
  stepKey        String   @unique
  question       String?
  agentVideoUrl  String?
  guideVideoUrl  String?
  guideTitle     String?
  options        Json?
  order          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AssistantGuide {
  id            Int      @id @default(autoincrement())
  pagePath      String?
  title         String
  script        String?
  textContent   String?
  videoUrl      String?
  agentVideoUrl String?
  toolSlug      String?
  sections      Json?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([pagePath])
  @@index([toolSlug])
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  RUNNING
  COMPLETED
  FAILED
}

enum LessonType {
  VIDEO
  DOCS
  TEXT
  ALL
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
}

enum Role {
  ADMIN
  STUDENT
  INSTRUCTOR
  AFFILIATE
  TEACHER
}

enum CourseType {
  NORMAL
  CHALLENGE
  LIB
  SYS
}

enum AffiliateStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum RefType {
  USER_ID
  AFFILIATE_CODE
  CUSTOM_ALIAS
  CAMPAIGN
}

enum ConversionStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum CommissionStatus {
  PENDING
  AVAILABLE
  WITHDRAWN
  CANCELLED
}

enum PointStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum TransactionType {
  COMMISSION
  WITHDRAWAL
  REFUND
  ADJUSTMENT
  POINT_EARNED
  POINT_REDEEMED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  REJECTED
  FAILED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  CANCELLED
}

enum PaymentMethod {
  FREE
  PAID
  POINT_REDEMPTION
  SYSTEM_GRANT
}

enum ProductType {
  COURSE
  POINT_REDEMPTION
}

enum SystemType {
  TCA
  KTC
}

enum BrkMemberStatus {
  PENDING
  ACTIVE
  CANCELLED
  EXPIRED
}

enum BrkTransactionType {
  RETURN_FEE
  REVENUE_SHARE
  COMMISSION
  LEVEL_BONUS
  REFERRAL_BONUS
  WITHDRAWAL
  ADJUSTMENT
  BRKD_CREDIT
  VOUCHER_CREDIT
  BRKD_RETURN
}

enum BalanceType {
  CASH
  BRKD
  VOUCHER
}

enum BrkRevenuePoolStatus {
  PENDING
  DISTRIBUTED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
  CANCELLED
}

enum BankAccountType {
  BANK
  MOMO
  ZALOPAY
  OTHER
}

model UserBankAccount {
  id             Int             @id @default(autoincrement())
  userId         Int
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountType    BankAccountType @default(BANK)
  accountHolder  String
  accountNumber  String
  bankName       String?
  qrCodeUrl      String?
  isDefault      Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  courses        Course[] @relation("CourseTeacherBank")

  @@index([userId])
}
