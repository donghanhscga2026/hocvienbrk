  REJECTED
  PAID
}

enum CommissionStatus {
  PENDING
  AVAILABLE
  WITHDRAWN
  CANCELLED
}

enum PointStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum TransactionType {
  COMMISSION
  WITHDRAWAL
  REFUND
  ADJUSTMENT
  POINT_EARNED
  POINT_REDEEMED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  REJECTED
  FAILED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  CANCELLED
