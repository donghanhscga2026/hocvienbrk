{
  "manifest_version": 3,
  "name": "TCA to BRK Sync",
  "version": "7.2.0",
  "description": "Sync TCA to BRK v7.2.0 - Mở rộng 10 cột mới (Điểm CN, Điểm Đội, Ngày Gia Nhập, Ngày Nộp HĐ, Ngày Thăng Hạng, BH, TD, % CN, % Đội, Cấp TV)",
  "permissions": [
    "activeTab",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "*://portal.tca.com.vn/*",
    "*://giautoandien.io.vn/*"
  ],
  "action": {
    "default_title": "TCA Sync"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://portal.tca.com.vn/*"],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected-script.js"],
      "matches": ["*://portal.tca.com.vn/*"]
    }
  ]
}
