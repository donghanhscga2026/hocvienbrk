generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              Int          @id @default(autoincrement())
  name            String?
  email           String       @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  passwordChanged  Boolean      @default(false)  // TRUE sau khi đổi mật khẩu từ mặc định
  phone           String?      @unique
  role            Role         @default(STUDENT)
  referrerId      Int?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  accounts        Account[]
  enrollments      Enrollment[]
  sessions        Session[]
  lessonComments   LessonComment[] @relation("UserToLessonComment")
  posts           Post[]          @relation("UserToPost")
  postComments    PostComment[]   @relation("UserToPostComment")
  referrer        User?        @relation("ReferrerToReferee", fields: [referrerId], references: [id])
  referrals       User[]       @relation("ReferrerToReferee")
  
  // Closure Table relations
  closureAsAncestor   UserClosure[] @relation("ClosureAncestor")
  closureAsDescendant UserClosure[] @relation("ClosureDescendant")
  
  // System relations (TCA/KTC) - bỏ unique để cho phép nhiều cây
  systems System[]

  // TCA Member relation (1 user có thể có nhiều TCA membership)
  tcaMembers TCAMember[]
  
  // Zero 2 Hero Data - Tách sang bảng UserRoadmap
  roadmap       UserRoadmap?
  emailCampaigns EmailCampaign[] @relation("UserToEmailCampaign")

  // Affiliate System fields
  affiliateCode    String?   @unique  // Mã CTV duy nhất (VD: "BRK123456")
  bankAccount     String?   // Số tài khoản
  bankName        String?   // Tên ngân hàng (VD: "VietinBank")
  bankHolder      String?   // Tên chủ tài khoản
  idCardNumber    String?   // CMND/CCCD
  
  // Affiliate Relations
  affiliateLinks      AffiliateLink[]
  registrationPointsAsReferrer  RegistrationPoint[] @relation("ReferrerRegistration")
  registrationPointsAsReferee  RegistrationPoint[] @relation("RefereeRegistration")
  commissions          AffiliateCommission[]
  wallet               AffiliateWallet?
  affiliatePayouts     AffiliatePayout[]
  affiliateRefs        AffiliateRef[]
  
  // [SITE_PROFILE] Khóa học do user giảng dạy
  courses             Course[]
  // [SITE_PROFILE] SiteProfile của user (nếu là Teacher)
  siteProfile         SiteProfile?

  @@index([email])
  @@index([phone])
  @@index([referrerId])
  @@index([affiliateCode])
}

// Closure Table cho Genealogy Tree - Tối ưu truy vấn descendants
// Lưu tất cả cặp ancestor-descendant để query O(1) thay vì đệ quy
model UserClosure {
    ancestorId   Int @map("ancestor_id")
    descendantId Int @map("descendant_id")
    depth        Int @default(0)

    ancestor   User @relation("ClosureAncestor", fields: [ancestorId], references: [id])
    descendant User @relation("ClosureDescendant", fields: [descendantId], references: [id])

    @@id([ancestorId, descendantId])
    @@index([ancestorId])
    @@index([descendantId])
    @@index([depth])
    @@map("user_closure")
}

model EmailSender {
  id              Int      @id @default(autoincrement())
  label           String                    // Tên gợi nhớ (VD: "Vệ tinh 01")
  email           String   @unique
  isMain          Boolean  @default(false)  // Email chính hocvienbrk@gmail.com
  clientId        String                    // GMAIL_CLIENT_ID (Lưu chung hoặc riêng tùy chọn, ở đây cho phép lưu riêng nếu cần)
  clientSecret    String?                   // Mã hóa AES-256
  refreshToken    String   @db.Text         // Mã hóa AES-256
  dailyLimit      Int      @default(480)    // Giới hạn gửi /ngày (an toàn dưới 500)
  sentToday       Int      @default(0)      // Đếm số đã gửi hôm nay
  lastResetAt     DateTime @default(now())  // Ngày reset sentToday
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  // Email Delivery Optimization fields
  staggerDelayMin    Int       @default(5)    // Phút chờ riêng (stagger) - tối thiểu
  staggerDelayMax    Int       @default(15)   // Phút chờ riêng - tối đa  
  maxPerBatch        Int       @default(20)   // Số mail mỗi lần trước khi stagger (tăng từ 15 lên 20)
  pauseDurationMin   Int       @default(10)   // Phút pause tối thiểu giữa các batch (giảm từ 15 xuống 10)
  pauseDurationMax   Int       @default(30)    // Phút pause tối đa giữa các batch
  warmupPhase        Int       @default(0)    // 0=ready, 1-4=warmup weeks (sẽ auto tính theo createdAt)
  lastUsedAt         DateTime?               // Thời gian gửi email cuối cùng
  cooldownUntil      DateTime?               // Thời gian được phép gửi tiếp (sau khi cooldown)
  campaigns          EmailCampaignSender[]
}

model EmailCampaign {
  id                Int            @id @default(autoincrement())
  title             String
  status            CampaignStatus @default(DRAFT)
  notificationType  String         // NEW_LESSON | ZOOM_SESSION | NEW_POST | ANNOUNCEMENT | CUSTOM
  linkedEntityId    String?        // ID bài học / bài đăng liên quan
  recipientSource   String         // DB_ALL | DB_ACTIVE | DB_COURSE | CSV
  recipientFilter   Json?          // { courseId } nếu lọc theo khóa
  recipientCsvData  String?        @db.Text
  subject           String
  htmlContent       String         @db.Text
  totalRecipients   Int            @default(0)
  sentCount         Int            @default(0)
  failedCount       Int            @default(0)
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  createdBy         Int
  creator           User           @relation("UserToEmailCampaign", fields: [createdBy], references: [id])
  senders           EmailCampaignSender[]
  logs              EmailCampaignLog[]
}

model EmailCampaignSender {
  id          Int           @id @default(autoincrement())
  campaignId  Int
  senderId    Int
  assignedCount Int         @default(0) // Số email được phân công cho sender này
  sentCount   Int           @default(0)
  campaign    EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sender      EmailSender   @relation(fields: [senderId], references: [id])
}

model EmailCampaignLog {
  id          Int      @id @default(autoincrement())
  campaignId  Int
  senderId    Int?     // Gửi từ email nào
  toEmail     String
  status      String   // SENT | FAILED | SKIPPED | BOUNCED
  errorCode   String?  // VD: "5.1.1 user unknown", "550 mailbox full"
  errorType   String?  // HARD_BOUNCE | SOFT_BOUNCE | INVALID | TIMEOUT
  sentAt      DateTime @default(now())
  campaign    EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model EmailBlacklist {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  reason      String   // HARD_BOUNCE | UNSUBSCRIBED | MANUAL
  campaignId  Int?     // Campaign phát hiện ra (nếu có)
  createdAt   DateTime @default(now())
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  RUNNING
  COMPLETED
  FAILED
}

model UserRoadmap {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetPointId   Int      @default(1) // Điểm đích trên Timeline (1-9)
  customPath      Json?    // Danh sách ID khóa học lộ trình
  goal            Json?    // Mục tiêu & Cam kết (JSON structuredGoal)
  surveyResults   Json?    // Kết quả khảo sát thô hiện tại
  history         Json?    // Mảng chứa các bản ghi cũ [ {targetPointId, customPath, goal, surveyResults, timestamp} ]
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model RoadmapPoint {
  id        Int      @id
  label     String
  description String?
  color     String?
}

model Post {
  id        String        @id @default(cuid())
  title     String
  content   String        @db.Text
  image     String?
  published Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  authorId  Int
  author    User          @relation("UserToPost", fields: [authorId], references: [id], onDelete: Cascade)
  comments  PostComment[]
  
  // [COMMUNITY_CUSTOMIZATION] Category filter
  categoryId Int?
  category   PostCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([authorId])
  @@index([categoryId])
}

model PostComment {
  id        Int      @id @default(autoincrement())
  postId    String
  userId    Int
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation("UserToPostComment", fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

// [COMMUNITY_CUSTOMIZATION] Categories for posts
model PostCategory {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String?  @unique
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  
  posts       Post[]

  @@index([order])
}

model Account {
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model SystemConfig {
  key   String @id
  value Json
}

model Survey {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  flow        Json     // Lưu trữ nodes và edges của React Flow
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // [SITE_PROFILE] Survey riêng cho SiteProfile nào (null = dùng chung)
  profileId   Int?
  profile     SiteProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  @@index([profileId])
}

model ReservedId {
  id        Int      @id
  note      String?
  createdAt DateTime @default(now())
}

model Course {
  id            Int          @id @default(autoincrement())
  id_khoa       String       @unique
  name_lop      String
  name_khoa     String?
  date_join     String?
  status        Boolean      @default(true)
  pin           Int          @default(0)
  mo_ta_ngan    String?
  mo_ta_dai     String?
  link_anh_bia  String?      @map("link_anh_bia_khoa")
  link_zalo     String?
  phi_coc       Int          @default(0)
  stk           String?
  name_stk      String?
  bank_stk      String?
  noidung_stk   String?
  link_qrcode   String?
  file_email    String?
  noidung_email String?
  category      String       @default("Khác")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  type          CourseType   @default(NORMAL)
  lessons       Lesson[]
  enrollments   Enrollment[]
  landingPages  LandingPage[]
  testimonials  CourseTestimonial[]
  libAccesses   CourseLibAccess[]
  
  // [SITE_PROFILE] Giáo viên chịu trách nhiệm khóa học
  teacherId     Int?
  teacher       User?       @relation(fields: [teacherId], references: [id])
  
  @@index([teacherId])
}

model Lesson {
  id               String           @id @default(cuid())
  courseId         Int
  title            String
  videoUrl         String?
  content          String?
  order            Int
  isDailyChallenge Boolean          @default(false)
  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress         LessonProgress[]
  comments         LessonComment[]

  @@unique([courseId, order])
}

model Enrollment {
  id           Int              @id @default(autoincrement())
  userId       Int
  courseId     Int
  status       EnrollmentStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  link_anh_coc String?
  phi_coc      Int              @default(0)
  startedAt    DateTime?
  resetAt      DateTime?
  lastLessonId String?
  challengeDays Int?
  course       Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]
  payment      Payment?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model LessonProgress {
  id           Int        @id @default(autoincrement())
  enrollmentId Int
  lessonId     String
  scores       Json?
  totalScore   Int        @default(0)
  assignment   Json?
  status       String     @default("IN_PROGRESS")
  maxTime      Float      @default(0)
  duration     Float      @default(0)
  submittedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@index([lessonId])
  @@index([status])
}

model LessonComment {
  id        Int      @id @default(autoincrement())
  lessonId  String
  userId    Int
  content   String
  createdAt DateTime @default(now())
  user      User     @relation("UserToLessonComment", fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([userId])
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  detail    String
  imageUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
}

enum Role {
  ADMIN
  STUDENT
  INSTRUCTOR
  AFFILIATE
  TEACHER
}

enum CourseType {
  NORMAL
  CHALLENGE
  LIB
}

model CourseLibAccess {
  id          Int       @id @default(autoincrement())
  courseId    Int
  email       String    // Email được cấp quyền xem
  createdAt   DateTime  @default(now())
  
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@unique([courseId, email])
  @@index([courseId])
  @@index([email])
}


// ==========================================
