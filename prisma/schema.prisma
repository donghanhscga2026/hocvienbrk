  TCA
  KTC
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
  CANCELLED
}

model Payment {
  id              Int            @id @default(autoincrement())
  enrollmentId    Int            @unique
  amount          Int
  bankName        String?
  accountNumber   String?
  transferTime    DateTime?
  content         String?
  phone           String?
  courseCode      String?
  proofImage      String?
  status          PaymentStatus  @default(PENDING)
  verifiedAt      DateTime?
  verifyMethod    String?
  note            String?
  transferContent String?
  qrCodeUrl       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  enrollment      Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

model YouTubeToken {
  id           Int       @id @default(autoincrement())
  userId       Int       @unique
  channelId    String?
  channelTitle String?
  accessToken  String    @db.Text
  refreshToken String    @db.Text
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ==========================================
// SYSTEM FEATURE - He thong TCA/KTC
// ==========================================

// Thong tin he thong cua user (TCA=1, KTC=2)
model System {
  autoId    Int       @id @default(autoincrement())  // ID tu dong cho phep refSysId
  userId    Int       @unique  // Lien ket voi User.id
  onSystem  Int       // 1=TCA, 2=KTC
  refSysId  Int       @default(0)  // UserID cua F1 trong he thong (0 = root)
  createdAt DateTime  @default(now())
  
  user       User           @relation(fields: [userId], references: [id])
  upline     System?        @relation("SystemUpline", fields: [refSysId], references: [userId])
  referrals  System[]       @relation("SystemUpline")
  closuresAsAncestor   SystemClosure[] @relation("SystemClosureAncestor")
  closuresAsDescendant SystemClosure[] @relation("SystemClosureDescendant")
  
  @@index([userId])
  @@index([onSystem])
  @@index([refSysId])
  @@map("system")
}

// Closure Table cho System Tree - toi uu query theo he thong
model SystemClosure {
  ancestorId   Int
  descendantId Int
  depth        Int     @default(0)
  systemId     Int     // 1=TCA, 2=KTC
  
  ancestor   System @relation("SystemClosureAncestor", fields: [ancestorId], references: [autoId])
  descendant System @relation("SystemClosureDescendant", fields: [descendantId], references: [autoId])
  
  @@id([ancestorId, descendantId, systemId])
  @@index([ancestorId])
  @@index([descendantId])
  @@index([systemId])
  @@index([depth])
  @@map("system_closure")
}

// ==========================================
// THEME SYSTEM - 2026-03-30
// ==========================================

model Theme {
  id            String   @id
  name          String
  description   String?
  colors        Json
  typography    Json
  layout        Json
  animations    Json?
  effects       Json?
  isLocked      Boolean  @default(false)
  isActive      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  siteSettings  SiteSettings?

  @@index([id])
}

// ==========================================
// LANDING PAGE MODULE - 2026-04-03
// ==========================================

model LandingPage {
  id            Int      @id @default(autoincrement())
  slug          String   @unique  // URL slug: "hocxaykenh", "tiktok-2025"
  
  // Content
  title         String
  subtitle      String?
  description   String?  @db.Text
  heroImage     String?
  ctaText       String   @default("Đăng ký ngay")
  ctaLink       String?  // Custom CTA link (default: /register)
  
  // Template
  template      String   @default("hero-cta")  // "hero-cta", "feature-grid", "video-intro", "webinar-reg", "testimonial"
  config        Json?    // Template-specific settings: { backgroundColor, textColor, accentColor, features[], etc. }
  
  // Commission override per landing
  customCommission Json?  // { f1: 15, f2: 7, f3: 3 } - override campaign commission
  
  // Relations
  courseId      Int?
  course        Course?  @relation(fields: [courseId], references: [id])
  
  // Stats
  viewCount     Int      @default(0)
  clickCount    Int      @default(0)
  
  // Status
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  clicks        AffiliateClick[]
  conversions   AffiliateConversion[]
  registrations RegistrationPoint[]
  
  @@index([slug])
  @@index([isActive])
  @@index([courseId])
}

// ==========================================
// AFFILIATE SYSTEM MODELS - Phase 1
// ==========================================

// Chiến dịch Affiliate (Campaign)
model AffiliateCampaign {
  id            Int       @id @default(autoincrement())
  name          String
  slug          String    @unique  // URL-friendly: "chuong-trinh-1"
  description   String?
  isActive      Boolean   @default(true)
  isDefault     Boolean   @default(false)  // Campaign mac dinh
  
  // Commission settings
  maxLevels     Int       @default(3)  // Số tầng hoa hồng tối đa
  pendingDays   Int       @default(30) // Ngày chờ pending trước khi available
  
  // Payout settings
  minPayout     Float     @default(200000) // Số dư tối thiểu để rút
  taxRate       Float     @default(0)      // % thuế (0 = miễn thuế)
  feeAmount     Float     @default(3300)   // Phí chuyển khoản
  
  // Points settings
  pointsPerRegistration  Float    @default(1.0)   // Điểm/đăng ký xác thực
  pointsRequired        Float    @default(10.0)   // Điểm cần để đổi
  pointRedemptionValue  Float    @default(386868) // Giá trị quy đổi (1 khóa L1)
  autoRedeem           Boolean   @default(false)  // Tự động đổi hay manual
  
  // Redemption course
  redemptionCourseId    Int?     // Khóa học được đổi (Level 1)
  
  // Landing page commission overrides
  landingOverrides Json?  // { "hocxaykenh": { f1: 15, f2: 7, f3: 3 }, ... }
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  levels        AffiliateLevel[]
  links         AffiliateLink[]
  conversions   AffiliateConversion[]
  registrations RegistrationPoint[]
  
  @@index([isActive])
}

// Cau hinh muc hoa hong theo tang
model AffiliateLevel {
  id          Int                @id @default(autoincrement())
  campaignId  Int
  campaign    AffiliateCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  level       Int                // 1 = F1, 2 = F2, 3 = F3...
  percentage  Float              // % hoa hồng (VD: 10.0 = 10%)
  minOrder    Float?             // Đơn hàng tối thiểu để nhận hoa hồng
  
  @@unique([campaignId, level])
  @@index([campaignId])
}

// Link affiliate cua CTV
model AffiliateLink {
  id          Int                @id @default(autoincrement())
  userId      Int
  campaignId  Int
  campaign    AffiliateCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  code        String             @unique  // Mã: "ABC123XYZ"
  name        String?            // Tên chiến dịch con: "Link Facebook", "Banner 1"
  source      String?            // facebook, zalo, google, email, website...
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  
  // Relations
  user        User               @relation(fields: [userId], references: [id])
  clicks      AffiliateClick[]
  conversions AffiliateConversion[]
  
  @@unique([userId, campaignId, name])
  @@index([userId])
  @@index([campaignId])
}

// Lich su click
model AffiliateClick {
  id          Int           @id @default(autoincrement())
  linkId      Int
  link        AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  ipAddress   String?
  userAgent   String?
  referer     String?
  url         String?       // Trang đích
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  deviceType  String?      // desktop, mobile, tablet
  country     String?
  city        String?
  
  // Landing page tracking
  landingSlug   String?      // LandingPage.slug (denormalized)
  landingId     Int?
  landing       LandingPage? @relation(fields: [landingId], references: [id])
  
  createdAt   DateTime      @default(now())
  
  @@index([linkId, createdAt])
  @@index([ipAddress, createdAt])
  @@index([landingSlug])
  @@index([landingId])
}

// Custom ref mapping (nbcuong -> userId, video -> userId, etc)
model AffiliateRef {
  id          Int       @id @default(autoincrement())
  refKey      String    @unique // max 10 chars, a-z0-9
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  type        RefType   @default(USER_ID)
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([userId])
}

// Conversion (khi co don hang)
model AffiliateConversion {
  id            Int                    @id @default(autoincrement())
  linkId        Int
  link          AffiliateLink          @relation(fields: [linkId], references: [id], onDelete: Cascade)
  campaignId    Int
  campaign      AffiliateCampaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId    Int                    // User mua khóa học
  enrollmentId Int?                   // Enrollment ID
  orderId      String?                 // Mã đơn hàng
  orderAmount  Float                  // Số tiền đơn hàng
  productType  ProductType            @default(COURSE)
  status        ConversionStatus       @default(PENDING)
  fraudFlags   String[]               // ["SAME_IP", "SELF_REFERRAL"]
  pendingUntil DateTime               // = createdAt + pendingDays
  approvedAt   DateTime?
  createdAt    DateTime               @default(now())
  
  // Landing page tracking
  landingSlug   String?      // LandingPage.slug
  landingId     Int?
  landing       LandingPage? @relation(fields: [landingId], references: [id])
  
  // Relations
  commissions  AffiliateCommission[]
  
  @@index([campaignId, status])
  @@index([customerId])
  @@index([pendingUntil])
  @@index([landingSlug])
  @@index([landingId])
}

// Diem dang ky - khi user moi xac thuc email
model RegistrationPoint {
  id              Int               @id @default(autoincrement())
  referrerId      Int               // Nguoi gioi thieu (F1)
  refereeId       Int               // Nguoi duoc gioi thieu
  campaignId      Int
  campaign        AffiliateCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  points          Float             @default(1.0)
  status          PointStatus       @default(PENDING)
  earnedAt        DateTime          @default(now())
  confirmedAt     DateTime?         // Khi xac thuc email thanh cong
  
  // Landing page tracking
  landingSlug     String?
  landingId       Int?
  landing         LandingPage?      @relation(fields: [landingId], references: [id])
  
  // Relations
  referrer        User              @relation("ReferrerRegistration", fields: [referrerId], references: [id])
  referee         User              @relation("RefereeRegistration", fields: [refereeId], references: [id])
  
  @@index([referrerId])
  @@index([refereeId])
  @@index([campaignId])
  @@index([status])
  @@index([landingSlug])
}

// Hoa hong cua CTV
model AffiliateCommission {
  id            Int               @id @default(autoincrement())
  conversionId  Int
  conversion    AffiliateConversion @relation(fields: [conversionId], references: [id], onDelete: Cascade)
  affiliateId   Int
  level         Int               // 1 = F1, 2 = F2, 3 = F3...
  percentage    Float             // % duoc ap dung
  grossAmount   Float             // So tien goc
  taxAmount     Float             @default(0)
  feeAmount     Float             @default(0)
  netAmount     Float             // Thuc nhan = grossAmount - tax - fee
  status        CommissionStatus  @default(PENDING)
  availableAt   DateTime?         // Khi nao available de rut
  paidAt        DateTime?
  createdAt     DateTime          @default(now())
  
  // Relations
  affiliate     User              @relation(fields: [affiliateId], references: [id])
  
  @@index([affiliateId, status])
  @@index([availableAt])
}

// Vi cua CTV (chua diem + tien)
model AffiliateWallet {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  user           User     @relation(fields: [userId], references: [id])
  
  // Points
  points         Float    @default(0)     // Diem dang ky (khong het han)
  
  // Money
  balance        Float    @default(0)      // Co the rut ngay
  pendingBalance Float    @default(0)      // Dang cho pending
  totalEarned    Float    @default(0)      // Tong da kiem
  totalPaid      Float    @default(0)     // Tong da rut
  
  updatedAt      DateTime @updatedAt
  
  // Relations
  transactions    AffiliateTransaction[]
  
  @@index([userId])
}

// Lich su giao dich vi
model AffiliateTransaction {
  id              Int              @id @default(autoincrement())
  walletId        Int
  wallet          AffiliateWallet  @relation(fields: [walletId], references: [id])
  amount          Float            // +/- so tien
  type            TransactionType
  description     String
  refId           String?          // Lien ket: payout_id, commission_id
  balanceBefore   Float
  balanceAfter    Float
  status          TransactionStatus @default(COMPLETED)
  createdAt       DateTime         @default(now())
  
  @@index([walletId, createdAt])
  @@index([type])
}

// Yeu cau rut tien
model AffiliatePayout {
  id            Int            @id @default(autoincrement())
  userId        Int
  user          User           @relation(fields: [userId], references: [id])
  amount        Float          // So tien yeu cau
  taxAmount     Float          @default(0)
  feeAmount     Float          @default(0)
  netAmount     Float          // Thuc nhan
  bankName      String
  bankAccount   String
  accountHolder String
  qrCodeUrl     String?        // VietQR
  status        PayoutStatus   @default(PENDING)
  notes         String?
  processedAt   DateTime?
  createdAt     DateTime       @default(now())
  
  @@index([status])
  @@index([userId, status])
}

model SiteSettings {
  id          String   @id @default("global")
  themeId     String   @default("classic")
  language    String   @default("vi")
  updatedAt   DateTime @updatedAt
  
  theme       Theme    @relation(fields: [themeId], references: [id])

  @@unique([themeId])
}

model CourseTestimonial {
  id          Int       @id @default(autoincrement())
  courseId    Int
  name        String
  role        String?
  avatar      String?
  content     String
  rating      Int       @default(5)
  courseName  String?
  isFeatured  Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@index([courseId, isActive])
  @@index([isFeatured])
}

model Tool {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  url         String
  roles       Role[]
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([slug])
}
