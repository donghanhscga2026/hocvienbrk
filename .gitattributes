# Auto detect text files and perform LF normalization on check-in
* text=auto

# Code source files enforce LF line endings
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.prisma text eol=lf
