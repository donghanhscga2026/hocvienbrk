  TCA
  KTC
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
  CANCELLED
}

model Payment {
  id              Int            @id @default(autoincrement())
  enrollmentId    Int            @unique
  amount          Int
  bankName        String?
  accountNumber   String?
  transferTime    DateTime?
  content         String?
  phone           String?
  courseCode      String?
  proofImage      String?
  status          PaymentStatus  @default(PENDING)
  verifiedAt      DateTime?
  verifyMethod    String?
  note            String?
  transferContent String?
  qrCodeUrl       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  enrollment      Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

model YouTubeToken {
  id           Int       @id @default(autoincrement())
  userId       Int       @unique
  channelId    String?
  channelTitle String?
  accessToken  String    @db.Text
  refreshToken String    @db.Text
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ==========================================
// SYSTEM FEATURE - He thong TCA/KTC
// ==========================================

// ==========================================
// SYSTEM TREE - 2026-04-10
// ==========================================

model SystemTree {
  id          Int      @id @default(autoincrement())
  onSystem    Int      @unique // 0=Học viên, 1=TCA, 2=KTC
  nameSystem  String   @map("name_system") // Tên của hệ thống
  createdAt   DateTime @default(now())
  
  @@map("system_tree")
}

// Thong tin he thong cua user (TCA=1, KTC=2)
// Link với SystemTree qua treeId
model System {
  autoId    Int       @id @default(autoincrement())
  userId    Int       // Lien ket voi User.id
  onSystem  Int       // 1=TCA, 2=KTC (cũng là SystemTree.id)
  refSysId  Int       @default(0)  // UserID cua F1 trong he thong (0 = root)
  createdAt DateTime  @default(now())
  
  user       User             @relation(fields: [userId], references: [id])
  closuresAsAncestor   SystemClosure[] @relation("SystemClosureAncestor")
  closuresAsDescendant SystemClosure[] @relation("SystemClosureDescendant")
  
  @@unique([userId, onSystem]) // 1 user per system
  @@index([userId])
  @@index([onSystem])
  @@index([refSysId])
  @@map("system")
}

// Closure Table cho System Tree - toi uu query theo he thong
model SystemClosure {
  ancestorId   Int
  descendantId Int
  depth        Int     @default(0)
  systemId     Int     // 1=TCA, 2=KTC
  
  ancestor   System @relation("SystemClosureAncestor", fields: [ancestorId], references: [autoId])
  descendant System @relation("SystemClosureDescendant", fields: [descendantId], references: [autoId])
  
  @@id([ancestorId, descendantId, systemId])
  @@index([ancestorId])
  @@index([descendantId])
  @@index([systemId])
  @@index([depth])
  @@map("system_closure")
}

// ==========================================
// TCA SYNC SYSTEM - 2026-04-17
// ==========================================

// Lưu thông tin TCA từ Portal, liên kết với User qua userId
model TCAMember {
  id              Int       @id @default(autoincrement())
  tcaId          Int       @unique  // ID từ TCA Portal
  userId         Int       // FK → User.id

  // Tree data (từ group_tree)
  type           String    // 'folder' hoặc 'item'
  groupName      String?
  name           String
  personalScore  Decimal?  @db.Decimal(10, 3)
  totalScore     Decimal?  @db.Decimal(10, 3)
  level          Int?
  location       String?
  personalRate   String?
  teamRate       String?
  hasBH          Boolean   @default(false)
  hasTD          Boolean   @default(false)

  // Detail data (từ ajax_get_member_info)
  phone          String?
  email          String?
  address        String?
  joinDate       DateTime?
  contractDate   DateTime?
  promotionDate  DateTime?

  // TCA Hierarchy
  parentTcaId    Int?      // TCA ID của F1
  parentName    String?
  teamSize       Int       @default(0)

  // Tracking
  lastSyncedAt   DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id])

  @@index([tcaId])
  @@index([userId])
  @@index([parentTcaId])
  @@map("tca_member")
}

// Lưu lịch sử sync để rollback khi cần
model TCASyncHistory {
  id              Int       @id @default(autoincrement())
  syncId          String    // UUID cho mỗi lần sync
  action          String    // 'CREATE_USER', 'UPDATE_USER', 'CREATE_SYSTEM', 'UPDATE_SYSTEM', 'CREATE_TCA_MEMBER', 'UPDATE_TCA_MEMBER', 'CREATE_CLOSURE', 'UPDATE_REFERRER'
  tableName       String    // 'User', 'System', 'TCAMember', 'SystemClosure'
  recordId        Int?      // ID của record bị ảnh hưởng

  // Snapshot trước/sau khi thay đổi
  beforeData      Json?     // Dữ liệu cũ (null nếu là INSERT)
  afterData       Json?     // Dữ liệu mới (null nếu là DELETE)

  // Metadata
  tcaId           Int?      // TCA ID liên quan
  totalRecords    Int       // Số records trong sync này
  status          String    @default("PENDING")  // 'PENDING', 'COMPLETED', 'ROLLED_BACK'
  errorMessage    String?

  createdAt       DateTime  @default(now())

  @@index([syncId])
  @@index([tcaId])
  @@index([tableName])
  @@index([createdAt])
  @@map("tca_sync_history")
}

// ==========================================
// STAGING SYSTEM - Bảng đệm để Test dữ liệu
// ==========================================

model UserTest {
  id              Int          @id
  name            String?
  email           String       @unique
  phone           String?      @unique
  password        String?
  role            Role         @default(STUDENT)
  referrerId      Int?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  closureAsAncestor   UserClosureTest[] @relation("ClosureAncestorTest")
  closureAsDescendant UserClosureTest[] @relation("ClosureDescendantTest")
  systems             SystemTest[]
  tcaMembers          TCAMemberTest[]
}

model UserClosureTest {
    ancestorId   Int @map("ancestor_id")
    descendantId Int @map("descendant_id")
    depth        Int @default(0)

    ancestor   UserTest @relation("ClosureAncestorTest", fields: [ancestorId], references: [id])
    descendant UserTest @relation("ClosureDescendantTest", fields: [descendantId], references: [id])

    @@id([ancestorId, descendantId])
    @@map("user_closure_test")
}

model SystemTest {
  autoId    Int       @id @default(autoincrement())
  userId    Int       
  onSystem  Int       
  refSysId  Int       @default(0)
  createdAt DateTime  @default(now())
  
  user       UserTest             @relation(fields: [userId], references: [id])
  closuresAsAncestor   SystemClosureTest[] @relation("SystemClosureAncestorTest")
  closuresAsDescendant SystemClosureTest[] @relation("SystemClosureDescendantTest")
  
  @@unique([userId, onSystem])
  @@map("system_test")
}

model SystemClosureTest {
  ancestorId   Int
  descendantId Int
  depth        Int     @default(0)
  systemId     Int     
  
  ancestor   SystemTest @relation("SystemClosureAncestorTest", fields: [ancestorId], references: [autoId])
  descendant SystemTest @relation("SystemClosureDescendantTest", fields: [descendantId], references: [autoId])
  
  @@id([ancestorId, descendantId, systemId])
  @@map("system_closure_test")
}

